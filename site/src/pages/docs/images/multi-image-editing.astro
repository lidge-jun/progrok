---
import DocsLayout from '../../../layouts/DocsLayout.astro';
const title = 'Multi-Image Editing';
---

<DocsLayout title={title}>
<h1>Multi-Image Editing</h1>
<p>Combine up to 3 reference images in a single edit request. The model blends elements from all references according to your prompt.</p>
<h2>CLI</h2>
<pre><code>{`progrok image --ref style.png --ref subject.png "combine the style with the subject"`}</code></pre>
<h2>API</h2>
<pre><code>{`curl -X POST http://localhost:18645/v1/images/edits \
  -H 'Authorization: Bearer anything' \
  -H 'Content-Type: application/json' \
  -d '{
  "prompt": "combine the style with the subject",
  "images": [
    {"url": "https://example.com/style.png"},
    {"url": "https://example.com/subject.png"}
  ],
  "size": "1024x1024"
}'`}</code></pre>
</DocsLayout>

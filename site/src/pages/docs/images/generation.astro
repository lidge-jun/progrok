---
import DocsLayout from '../../../layouts/DocsLayout.astro';
const title = 'Image Generation';
---

<DocsLayout title={title}>
<h1>Image Generation</h1>
<p>Generate images from text prompts using the Grok image model.</p>
<h2>CLI</h2>
<pre><code>{`progrok image "a sunset over a cyberpunk city"`}</code></pre>
<h2>API</h2>
<pre><code>{`curl -X POST http://localhost:18645/v1/images/generations \
  -H 'Authorization: Bearer anything' \
  -H 'Content-Type: application/json' \
  -d '{
  "prompt": "a sunset over a cyberpunk city",
  "n": 1,
  "size": "1024x1024"
}'`}</code></pre>
<h2>Parameters</h2>
<table>
<tr><th>Parameter</th><th>Type</th><th>Description</th></tr>
<tr><td>prompt</td><td>string</td><td>Text description of the image to generate</td></tr>
<tr><td>n</td><td>integer</td><td>Number of images (1–4, default 1)</td></tr>
<tr><td>size</td><td>string</td><td>Image dimensions (1024x1024, 1536x1024, 1024x1536)</td></tr>
<tr><td>response_format</td><td>string</td><td>url or b64_json</td></tr>
</table>
</DocsLayout>

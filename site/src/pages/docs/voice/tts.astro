---
import DocsLayout from '../../../layouts/DocsLayout.astro';
const title = 'Text to Speech';
---

<DocsLayout title={title}>
<h1>Text to Speech</h1>
<p>Convert text to audio using <code>POST /v1/tts</code>. Returns audio data in the specified format.</p>
<pre><code>{`curl -X POST http://localhost:18645/v1/tts \
  -H "Authorization: Bearer $API_KEY" \
  -H "Content-Type: application/json" \
  -d '{
    "voice_id": "alloy",
    "text": "Hello, welcome to progrok.",
    "output_format": "mp3",
    "speed": 1.0
  }' --output speech.mp3`}</code></pre>
<table>
<tr><th>Parameter</th><th>Type</th><th>Description</th></tr>
<tr><td>voice_id</td><td>string</td><td>Voice identifier to use for synthesis</td></tr>
<tr><td>text</td><td>string</td><td>Text content to convert to speech</td></tr>
<tr><td>output_format</td><td>string</td><td>Audio format (mp3, wav, opus, flac)</td></tr>
<tr><td>speed</td><td>number</td><td>Playback speed multiplier (0.25–4.0)</td></tr>
</table>
</DocsLayout>

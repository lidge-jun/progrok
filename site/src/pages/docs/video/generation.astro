import DocsLayout from '../../../layouts/DocsLayout.astro';
const title = 'Video Generation';
---

<DocsLayout title={title}>
<h1>Video Generation</h1>
<p>Generate videos from text prompts. Video generation is asynchronous — submit a request, then poll for completion.</p>
<h2>CLI</h2>
<pre><code>{`progrok video "a drone flying over mountains at sunrise"`}</code></pre>
<h2>API</h2>
<pre><code>{`# Submit generation request
curl -X POST http://localhost:18645/v1/videos/generations \
  -H 'Authorization: Bearer anything' \
  -H 'Content-Type: application/json' \
  -d '{
  "prompt": "a drone flying over mountains at sunrise"
}'

# Poll for result
curl http://localhost:18645/v1/videos/generations/vg_abc123 \
  -H 'Authorization: Bearer anything'`}</code></pre>
<h2>Parameters</h2>
<table>
<tr><th>Parameter</th><th>Type</th><th>Description</th></tr>
<tr><td>prompt</td><td>string</td><td>Text description of the video</td></tr>
<tr><td>duration</td><td>integer</td><td>Length in seconds (5 or 10)</td></tr>
<tr><td>aspect_ratio</td><td>string</td><td>16:9, 9:16, or 1:1</td></tr>
</table>
<h2>Status Values</h2>
<p><code>pending</code> — Generation in progress.</p>
<p><code>done</code> — Video ready for download.</p>
<p><code>failed</code> — Generation failed.</p>
<p><code>expired</code> — Download URL has expired.</p>
</DocsLayout>

---
import DocsLayout from '../../../layouts/DocsLayout.astro';
const title = 'Image to Video';
---

<DocsLayout title={title}>
<h1>Image to Video</h1>
<p>Animate a static image into a video by providing an image URL alongside a motion prompt.</p>
<h2>CLI</h2>
<pre><code>{`progrok video --image photo.png "slow zoom out with parallax"`}</code></pre>
<h2>API</h2>
<pre><code>{`curl -X POST http://localhost:18645/v1/videos/generations \
  -H 'Authorization: Bearer anything' \
  -H 'Content-Type: application/json' \
  -d '{
  "prompt": "slow zoom out with parallax",
  "image": {"url": "https://example.com/photo.png"}
}'`}</code></pre>
</DocsLayout>

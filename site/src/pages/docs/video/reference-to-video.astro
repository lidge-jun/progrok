---
import DocsLayout from '../../../layouts/DocsLayout.astro';
const title = 'Reference to Video';
---

<DocsLayout title={title}>
<h1>Reference to Video</h1>
<p>Generate videos guided by reference images. Supply up to 7 images via the <code>reference_images</code> array. Each generated video has a maximum duration of 10 seconds.</p>
<pre><code>{`curl -X POST http://localhost:18645/v1/videos/generations \
  -H "Authorization: Bearer $API_KEY" \
  -H "Content-Type: application/json" \
  -d '{
    "prompt": "A cat walking through a garden",
    "reference_images": [
      {"url": "https://example.com/ref1.png"},
      {"url": "https://example.com/ref2.png"}
    ],
    "duration": 10
  }'`}</code></pre>
</DocsLayout>

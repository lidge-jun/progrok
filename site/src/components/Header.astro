---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string): string => `${base}${path}`;

const links = [
  { href: '/', label: 'Home' },
  { href: '/docs', label: 'Docs' },
  { href: '/docs/quickstart', label: 'Quick start' },
  { href: 'https://github.com/lidge-jun/progrok', label: 'GitHub', external: true },
];
---

<header class="site-header">
  <a class="skip-link" href="#content">Skip to content</a>
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="brand" href={withBase('/')}>
      <span class="brand-mark" aria-hidden="true">pg</span>
      <span>progrok</span>
    </a>
    <div class="nav-links">
      {links.map((link) => (
        <a
          href={link.external ? link.href : withBase(link.href)}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

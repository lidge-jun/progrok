---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string): string => `${base}${path}`;
---

<footer class="site-footer">
  <div>
    <strong>progrok</strong>
    <p>OAuth-activated Grok proxy and CLI tool surface.</p>
  </div>
  <nav aria-label="Footer navigation">
    <a href={withBase('/docs')}>Docs</a>
    <a href={withBase('/docs/concepts/oauth-bridge')}>OAuth</a>
    <a href={withBase('/docs/cli/search')}>Search CLI</a>
    <a href="https://github.com/lidge-jun/progrok" target="_blank" rel="noreferrer">GitHub</a>
    <a href="https://www.npmjs.com/package/progrok" target="_blank" rel="noreferrer">npm</a>
  </nav>
</footer>
